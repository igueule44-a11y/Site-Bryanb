{
  "trailingSlash": false,
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.omnyx.agency" }],
      "destination": "https://omnyx.agency/:path*",
      "permanent": true
    }
  ]
}
